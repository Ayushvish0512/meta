# Meta Ads
META_ACCESS_TOKEN=your_system_user_token_here
META_AD_ACCOUNT_ID=act_XXXXXXXXXX
META_PIXEL_ID=XXXXXXXXXX
META_API_VERSION=v19.0

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Postgres
POSTGRES_PASSWORD=change_me_strong_password

# Chroma
CHROMA_AUTH_TOKEN=change_me_chroma_token

# n8n
N8N_USER=admin
N8N_PASSWORD=change_me_n8n_password
N8N_ENCRYPTION_KEY=change_me_32char_encryption_key_here

# Campaign targets (tune per account)
TARGET_CPA=500
TARGET_ROAS=3.0
MAX_DAILY_BUDGET_CHANGE_PCT=20
FATIGUE_FREQ_THRESHOLD=3.5
MIN_CONVERSIONS_FOR_SCALE=10
ATTRIBUTION_WINDOW=7d_click
DATA_RETENTION_TTL_DAYS=90

# Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
ALERT_EMAIL=team@yourdomain.com
