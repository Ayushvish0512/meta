{
  "name": "04 - Action Proposal Queue (Human-in-Loop)",
  "nodes": [
    {
      "parameters": {},
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "webhookId": "action-proposal",
      "position": [240, 400]
    },
    {
      "parameters": {
        "jsCode": "const plan_id = 'plan_' + Date.now() + '_' + Math.random().toString(36).slice(2,7);\nreturn [{ json: { ...$json, plan_id } }];"
      },
      "name": "Generate Plan ID",
      "type": "n8n-nodes-base.code",
      "position": [460, 400]
    },
    {
      "parameters": {
        "conditions": {
          "string": [{ "value1": "={{$json.compliance_verdict}}", "operation": "equals", "value2": "PASS" }]
        }
      },
      "name": "Compliance Gate",
      "type": "n8n-nodes-base.if",
      "position": [700, 400]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO action_plans (plan_id, date, account_id, actions, compliance_verdict, status) VALUES ($1, NOW()::date, $2, $3::jsonb, $4, $5) RETURNING plan_id;",
        "queryParameters": "={{$json.plan_id}},{{$env.META_AD_ACCOUNT_ID}},={{JSON.stringify($json.actions)}},PASS,PENDING_APPROVAL"
      },
      "name": "Save Action Plan",
      "type": "n8n-nodes-base.postgres",
      "position": [940, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.SLACK_WEBHOOK_URL}}",
        "body": {
          "blocks": [
            {
              "type": "section",
              "text": { "type": "mrkdwn", "text": "🤖 *New Action Plan Ready for Approval*\nPlan ID: `{{$json.plan_id}}`\n\n{{$json.summary}}" }
            },
            {
              "type": "actions",
              "elements": [
                { "type": "button", "text": { "type": "plain_text", "text": "✅ Approve" }, "style": "primary", "value": "={{$json.plan_id}}|APPROVED", "action_id": "approve_plan" },
                { "type": "button", "text": { "type": "plain_text", "text": "❌ Reject" }, "style": "danger", "value": "={{$json.plan_id}}|REJECTED", "action_id": "reject_plan" }
              ]
            }
          ]
        }
      },
      "name": "Send Approval Request",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1180, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.SLACK_WEBHOOK_URL}}",
        "body": { "text": "⛔ Action plan blocked by Compliance Agent. Review required.\nPlan: {{$json.plan_id}}" }
      },
      "name": "Notify Compliance Fail",
      "type": "n8n-nodes-base.httpRequest",
      "position": [940, 500]
    }
  ],
  "connections": {
    "Webhook Trigger": { "main": [[{ "node": "Generate Plan ID" }]] },
    "Generate Plan ID": { "main": [[{ "node": "Compliance Gate" }]] },
    "Compliance Gate": {
      "main": [
        [{ "node": "Save Action Plan" }],
        [{ "node": "Notify Compliance Fail" }]
      ]
    },
    "Save Action Plan": { "main": [[{ "node": "Send Approval Request" }]] }
  }
}
